# Firebase Client (öffentlich)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin-E-Mail für automatische Admin-Rolle bei Registrierung
NEXT_PUBLIC_ADMIN_EMAIL=

# Firebase Admin SDK (JSON als eine Zeile, auf Vercel als Secret)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Cron-Job Schutz (Vercel setzt Authorization: Bearer <CRON_SECRET> automatisch)
CRON_SECRET=

# SMTP für Rechnungs- und Mahn-E-Mails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
